# load packages
library(tidyverse)
library(Sleuth3)
library(ggeffects)
library(effects)
library(multcomp)
library(yarrr)
library(emmeans)
# seaweed grazer data
glimpse(case1301)
df_grazers_logit <- case1301 |>
mutate(CoverLogit = log(Cover/(100-Cover)))
lm_add <- lm(CoverLogit ~ Treat + Block, data=df_grazers_logit)
levels(case1301$Treat)
emm_grazers_logit <- emmeans(lm_add, specs = ~Treat)
f_int <- c(-.5, -.5, .5, 0, .5, 0)
gam2 <- contrast(emm_grazers_logit, list(gamma2 = f_int))
gam2
confint(gam2)
f_int2 <- c((-1/3), (1/3), (1/3), (1/3), (-1/3), (-1/3))
gam3 <- contrast(emm_grazers_logit, list(gamma3 = f_int2))
gam3
confint(gam3)
# rename data
df_pyg <- ex1321
#Converted grade to a categorical variable for raw data plot
df_pyg$Grade_fact <- as.factor(df_pyg$Grade)
glimpse(df_pyg)
ggplot(df_pyg, aes(x = Grade_fact, y = Gain)) +
geom_violin() +
geom_jitter(aes(color = Treatment), width = 0.2, size = 1.5, alpha = 0.5)
ggplot(df_pyg, aes(x = Grade_fact, y = Gain)) +
geom_violin() +
geom_jitter(aes(color = Treatment), width = 0.2, size = 1.5, alpha = 0.5) +
labs(x = "Grade"
y = "Gain (post-pre)"
ggplot(df_pyg, aes(x = Grade_fact, y = Gain)) +
geom_violin() +
geom_jitter(aes(color = Treatment), width = 0.2, size = 1.5, alpha = 0.5) +
labs(x = "Grade",
y = "Gain (post-pre)",
title= "Violin Plot of Falsified Intelligence Test Student Gains Across Different Grades")
ggplot(df_pyg, aes(x = Grade_fact, y = Gain)) +
geom_violin() +
geom_jitter(aes(color = Treatment), width = 0.2, size = 1.5, alpha = 0.7) +
labs(x = "Grade",
y = "Gain (post-pre)",
title= "Violin Plot of Falsified Intelligence Test Student Gains Across Different Grades")
intplot(Gain~ Treatment * Grade_fact, data=df_pyg)
# load packages
library(tidyverse)
library(Sleuth3)
library(ggeffects)
library(effects)
library(multcomp)
library(yarrr)
library(emmeans)
library(catstats)
# seaweed grazer data
glimpse(case1301)
intplot(Gain~ Treatment * Grade_fact, data=df_pyg)
lm_int <- lm(Gain ~ Grade_fact*Treatment, data= df_pyg)
par(mfrow = c(2,2))
plot(lm_int, pch = 18)
lm_int <- lm(Gain ~ Grade_fact*Treatment, data= df_pyg)
par(mfrow = c(2,2))
plot(lm_int, pch = 18)
lm_add <- lm(Gain ~ Grade_fact+Treatment, data= df_pyg)
anova(lm_add, lm_int)
lm_add <- lm(Gain ~ Grade_fact+Treatment, data= df_pyg)
anova(lm_add, lm_int)
anova(lm_int)
plot(effect("Grade_fact:Treatment", lm_int))
#library(ggeffects)
#plot(ggpredict(lm_int, terms=c("Grade_fact", "Treatment"))) +
#  geom_line(lty=2)
plot(effect("Grade_fact:Treatment", lm_int))
library(ggeffects)
plot(ggpredict(lm_int, terms=c("Grade_fact", "Treatment"))) +
geom_line(lty=2)
plot(effect("Grade_fact:Treatment", lm_int))
library(ggeffects)
plot(ggpredict(lm_int, terms=c("Treatment", "Grade_fact"))) +
geom_line(lty=2)
intplot(Gain~ Treatment * Grade_fact, data=df_pyg)
