options(show.signif.stars = FALSE) #suppresses significance stars in output
# load packages
library(tidyverse)
library(Sleuth3)
library(effects)
library(multcomp)
library(yarrr)
library(emmeans)
# seaweed grazer data
glimpse(case1301)
df_grazers_logit <- case1301 |>
mutate(CoverLogit = log(Cover/(100-Cover)))
lm_add <- lm(CoverLogit ~ Treat + Block, data=df_grazers_logit)
levels(case1301$Treat)
emm_grazers_logit <- emmeans(lm_add, specs = ~Treat)
f_int <- c(-.5, -.5, .5, 0, .5, 0)
gam2 <- contrast(emm_grazers_logit, list(gamma2 = f_int))
gam2
confint(gam2)
f_int2 <- c((-1/3), (1/3), (1/3), (1/3), (-1/3), (-1/3))
gam3 <- contrast(emm_grazers_logit, list(gamma3 = f_int2))
gam3
confint(gam3)
# rename data
df_pyg <- ex1321
glimpse(df_pyg)
df_pyg$Grade <- as.factor(df_pyg$Grade)
ggplot(df_pyg, aes(x = Grade, y = Gain)) +
geom_violin() +
geom_jitter(aes(color = Treatment), width = 0.2, size = 1.5, alpha = 0.5) +
theme_minimal()
lm_int <- lm(Gain ~ Grade*Treatment, data= df_pyg)
par(mfrow = c(2,2))
plot(lm_int, pch = 18)
lm_add <- lm(Gain ~ Grade+Treatment, data= df_pyg)
anova(lm_add, lm_int)
lm_int <- lm(Gain ~ Treatment*Grade, data= df_pyg)
par(mfrow = c(2,2))
plot(lm_int, pch = 18)
lm_add <- lm(Gain ~ Treatment+Grade, data= df_pyg)
anova(lm_add, lm_int)
lm_trt_add <- lm( ~ Treatment+Grade, data= df_pyg)
lm_add <- lm(Gain ~ Treatment+Grade, data= df_pyg)
anova(lm_add, lm_int)
plot(effect("Treatment:Grade", lm_int))
plot(effect("Treatment:Grade", lm_int))
library(ggeffects)
plot(ggpredict(Gain, terms=c("Treatment", "Grade"))) +
geom_line(lty=2)
plot(effect("Treatment:Grade", lm_int))
library(ggeffects)
plot(ggpredict(df_pyg, terms=c("Treatment", "Grade"))) +
geom_line(lty=2)
plot(effect("Treatment:Grade", lm_int))
library(ggeffects)
plot(ggpredict(lm_int, terms=c("Treatment", "Grade"))) +
geom_line(lty=2)
plot(effect("Treatment:Grade", lm_int))
library(ggeffects)
plot(ggpredict(lm_int, terms=c("Grade", "Treatment"))) +
geom_line(lty=2)
